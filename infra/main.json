{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.43.8.12551",
      "templateHash": "4266103599268946538"
    }
  },
  "parameters": {
    "prefix": {
      "type": "string",
      "defaultValue": "agenticdemo",
      "metadata": {
        "description": "Short deployment prefix used for all new Azure resources."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region used for the App Service plan and API app."
      }
    },
    "appServicePlanName": {
      "type": "string",
      "defaultValue": "[format('{0}-{1}-asp', parameters('prefix'), replace(resourceGroup().name, '-', ''))]",
      "metadata": {
        "description": "Name of the Linux App Service plan for the API host."
      }
    },
    "apiAppName": {
      "type": "string",
      "defaultValue": "[format('{0}-{1}-api', parameters('prefix'), replace(resourceGroup().name, '-', ''))]",
      "metadata": {
        "description": "Name of the App Service instance that hosts the API and MCP server process."
      }
    },
    "staticWebAppName": {
      "type": "string",
      "defaultValue": "[format('{0}-{1}-web', parameters('prefix'), replace(resourceGroup().name, '-', ''))]",
      "metadata": {
        "description": "Name of the Static Web App that hosts the React frontend."
      }
    },
    "enableAlwaysOn": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Optional deployment slot settings for the API host."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-12-01",
      "name": "[parameters('appServicePlanName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "B1",
        "tier": "Basic",
        "size": "B1",
        "capacity": 1
      },
      "kind": "linux",
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[parameters('apiAppName')]",
      "location": "[parameters('location')]",
      "kind": "app,linux",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "httpsOnly": true,
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]",
        "siteConfig": {
          "alwaysOn": "[parameters('enableAlwaysOn')]",
          "linuxFxVersion": "DOTNETCORE|8.0",
          "appSettings": [
            {
              "name": "ASPNETCORE_URLS",
              "value": "http://0.0.0.0:8080"
            },
            {
              "name": "WEBSITES_PORT",
              "value": "8080"
            },
            {
              "name": "WEBSITE_RUN_FROM_PACKAGE",
              "value": "1"
            },
            {
              "name": "ASPNETCORE_ENVIRONMENT",
              "value": "Production"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/staticSites",
      "apiVersion": "2024-04-01",
      "name": "[parameters('staticWebAppName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard",
        "tier": "Standard"
      },
      "properties": {
        "allowConfigFileUpdates": true
      }
    }
  ],
  "outputs": {
    "appServiceDefaultHostName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', parameters('apiAppName')), '2023-12-01').defaultHostName]"
    },
    "appServiceUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/sites', parameters('apiAppName')), '2023-12-01').defaultHostName)]"
    },
    "staticWebAppDefaultHostName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/staticSites', parameters('staticWebAppName')), '2024-04-01').defaultHostname]"
    },
    "staticWebAppUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/staticSites', parameters('staticWebAppName')), '2024-04-01').defaultHostname)]"
    }
  }
}
